{
  "name": "bumn-master-system-be",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "auth:generate": "npx @better-auth/cli@latest generate --yes --output ./src/db/schema.ts --config ./src/auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:packages": "tsx scripts/seedPackages.ts",
    "seed:questions": "tsx scripts/seedQuestions.ts",
    "seed:latsol": "tsx scripts/seedLatsolSets.ts",
    "latsol:trim10": "tsx scripts/trimLatsolSetsTo10.ts",
    "prepare:finetune:verbal": "tsx scripts/generateFineTuneVerbal.ts"
  },
  "dependencies": {
    "better-auth": "^1.0.0",
    "better-sqlite3": "^12.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "doku-nodejs-library": "^1.0.52",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
